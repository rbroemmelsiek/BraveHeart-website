{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:auth\"",
    "dev:vite": "vite --port=3000 --host=0.0.0.0",
    "dev:auth": "node server/auth-api.mjs",
    "build": "node scripts/generate-sitemap.mjs && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "sitemap:generate": "node scripts/generate-sitemap.mjs",
    "start": "node server.mjs",
    "images:braveheart": "node scripts/convert-braveheart-images.mjs",
    "images:responsive": "node scripts/generate-responsive-images.mjs",
    "images:to-webp": "node scripts/convert-to-webp.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-oauth/google": "^0.12.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "pdf-to-img": "^6.2.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
